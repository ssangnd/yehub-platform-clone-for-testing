DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yehub?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"

# Worker process (separate `pnpm start:worker`) — health endpoints port
# WORKER_PORT=3001

# Timezone (IANA name) used to render dates in exported files
# EXPORT_TIMEZONE=Asia/Ho_Chi_Minh

# S3 / MinIO (local dev: MinIO via docker-compose)
S3_ENDPOINT=http://localhost:9000
# Only needed when S3_ENDPOINT is a Docker-internal hostname (e.g. http://minio:9000)
# S3_PUBLIC_ENDPOINT=http://localhost:9000
# Set to true for MinIO / path-style endpoints, false (default) for virtual hosted style
S3_FORCE_PATH_STYLE=true
S3_REGION=us-east-1
S3_BUCKET=yehub
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
SMTP_HOST=localhost
SMTP_PORT=2525

# Apify polling
APIFY_TOKEN=
# APIFY_TIMEOUT_MS=120000
# APIFY_MEMORY_MB=1024
# APIFY_USAGE_REFRESH_DELAY_MS=15000
# POLLING_PROCESSOR_CONCURRENCY=5
# APIFY_FACEBOOK_POSTS_ACTOR_ID=apify~facebook-posts-scraper
# APIFY_FACEBOOK_COMMENTS_ACTOR_ID=apify~facebook-comments-scraper
# APIFY_FACEBOOK_POSTS_LIMIT=25
# APIFY_FACEBOOK_COMMENTS_LIMIT=500
# APIFY_INSTAGRAM_POSTS_ACTOR_ID=apify~instagram-post-scraper
# APIFY_INSTAGRAM_COMMENTS_ACTOR_ID=apify~instagram-comment-scraper
# APIFY_INSTAGRAM_POSTS_LIMIT=5
# APIFY_INSTAGRAM_COMMENTS_LIMIT=10000
# APIFY_INSTAGRAM_PROFILE_ACTOR_ID=apify~instagram-profile-scraper
# APIFY_THREADS_POSTS_ACTOR_ID=logical_scrapers~threads-post-scraper
# APIFY_YOUTUBE_POSTS_ACTOR_ID=streamers~youtube-scraper
# APIFY_YOUTUBE_COMMENTS_ACTOR_ID=streamers~youtube-comments-scraper
# APIFY_YOUTUBE_POSTS_LIMIT=1
# APIFY_YOUTUBE_COMMENTS_LIMIT=10000
# APIFY_TIKTOK_POSTS_ACTOR_ID=clockworks~tiktok-scraper
# APIFY_TIKTOK_COMMENTS_ACTOR_ID=clockworks~tiktok-comments-scraper
# APIFY_TIKTOK_POSTS_LIMIT=1
# APIFY_TIKTOK_COMMENTS_LIMIT=10000
