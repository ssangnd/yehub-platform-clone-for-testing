# .ebextensions/01-secrets.config
# Fetches secrets from AWS Secrets Manager and injects as
# environment variables into the Elastic Beanstalk Docker container.
# Runs on every EC2 instance launch and redeployment.
#
# SECRET_NAME and AWS_REGION are set as Beanstalk env_vars in terragrunt.hcl

commands:
  01_fetch_and_inject_secrets:
    command: |
      #!/bin/bash
      set -eo pipefail

      SECRET_NAME="${SECRET_NAME}"
      REGION="${AWS_REGION:-ap-southeast-1}"
      ENV_FILE="/opt/elasticbeanstalk/deployment/env"

      if [ -z "$SECRET_NAME" ]; then
        echo "[secrets] SECRET_NAME not set, skipping."
        exit 0
      fi

      echo "[secrets] Fetching secret: $SECRET_NAME from region: $REGION"

      SECRET_JSON=$(aws secretsmanager get-secret-value \
        --secret-id "$SECRET_NAME" \
        --region "$REGION" \
        --query SecretString \
        --output text)

      echo "[secrets] Injecting into: $ENV_FILE"

      echo "$SECRET_JSON" | python3 -c "
import json, sys

data = json.load(sys.stdin)
env_file = open('$ENV_FILE', 'a')
count = 0

for key, value in data.items():
    if key.startswith('_'):
        continue  # skip internal/comment keys
    value = str(value).replace('\n', '\\n')
    env_file.write(f'{key}={value}\n')
    count += 1

env_file.close()
print(f'[secrets] Injected {count} environment variables.')
"
