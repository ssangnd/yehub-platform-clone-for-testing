commands:
  00_install_jq:
    command: "which jq || yum install -y jq"

  01_fetch_secrets:
    command: "/opt/elasticbeanstalk/hooks/secrets/fetch-secrets.sh"
    env:
      SECRET_NAME: '`{"Ref":"AWSEBEnvironmentName"}`'

files:
  "/opt/elasticbeanstalk/hooks/secrets/fetch-secrets.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -eo pipefail

      SECRET_NAME="${SECRET_NAME:-}"
      REGION="${AWS_REGION:-ap-southeast-1}"
      ENV_FILE="/opt/elasticbeanstalk/deployment/env.list"

      if [ -z "$SECRET_NAME" ]; then
        echo "[secrets] SECRET_NAME not set, skipping."
        exit 0
      fi

      echo "[secrets] Fetching: $SECRET_NAME"

      SECRET_JSON=$(aws secretsmanager get-secret-value \
        --secret-id "$SECRET_NAME" \
        --region "$REGION" \
        --query SecretString \
        --output text)

      echo "$SECRET_JSON" | jq -r 'to_entries[] | select(.key | startswith("_") | not) | "\(.key)=\(.value)"' >> "$ENV_FILE"

      echo "[secrets] Done."
