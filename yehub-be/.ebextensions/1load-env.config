###############################################################
# .ebextensions/env-secrets.config
# Fetches secrets from AWS Secrets Manager and writes them
# to /etc/environment so the Docker container picks them up
# at startup via --env-file in the Dockerrun.aws.json.
#
# Secret name: project-ecommerce-prod-app-sm
# Region:      ap-southeast-1
###############################################################

commands:
  01_install_jq:
    command: |
      if ! command -v jq &> /dev/null; then
        yum install -y jq
      fi

  02_fetch_secrets:
    command: |
      SECRET_NAME="project-ecommerce-prod-app-sm"
      REGION="ap-southeast-1"

      echo "Fetching secrets from $SECRET_NAME..."

      SECRET_JSON=$(aws secretsmanager get-secret-value \
        --secret-id "$SECRET_NAME" \
        --region "$REGION" \
        --query SecretString \
        --output text)

      if [ $? -ne 0 ]; then
        echo "ERROR: Failed to fetch secret $SECRET_NAME"
        exit 1
      fi

      # Write each key=value to /etc/environment
      # Docker will read this file via env_file in Dockerrun
      echo "$SECRET_JSON" | jq -r 'to_entries[] | "\(.key)=\(.value)"' > /etc/app-secrets.env

      echo "Secrets written to /etc/app-secrets.env"
      chmod 600 /etc/app-secrets.env
