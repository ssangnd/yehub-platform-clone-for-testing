# ============================================================
# Native Elastic Beanstalk secret injection (AL2023 Docker platform)
# Worker environment ONLY — see .ebextensions-api for the API env.
#
# Uses the aws:elasticbeanstalk:application:environmentsecrets namespace.
# EB fetches each value from Secrets Manager at instance bootstrap and
# injects it as a container environment variable (via env.list / --env-file).
#
# JSON-key extraction (append ":KEY" to the secret ARN) is supported on
# platform versions released on/after 2026-01-13.
#
# The ARN is an identifier, not a secret — safe to commit. Actual values
# stay in Secrets Manager.
#
# Requirements:
#   - EC2 instance role must allow secretsmanager:GetSecretValue on this ARN.
#   - One secret (yehubv1-prod-app-sm) is shared with the API env; each
#     env's ebextensions file only lists the keys that env actually needs.
#
# To refresh after rotating the secret: run update-environment or
# restart-app-server (EB only pulls values at bootstrap).
# ============================================================
option_settings:
  aws:elasticbeanstalk:application:environmentsecrets:
    DATABASE_URL:  arn:aws:secretsmanager:ap-southeast-1:629687551655:secret:yehubv1-prod-app-sm-y8jsgI:DATABASE_URL
    REDIS_URL:     arn:aws:secretsmanager:ap-southeast-1:629687551655:secret:yehubv1-prod-app-sm-y8jsgI:REDIS_URL
    S3_ENDPOINT:   arn:aws:secretsmanager:ap-southeast-1:629687551655:secret:yehubv1-prod-app-sm-y8jsgI:S3_ENDPOINT
    S3_REGION:     arn:aws:secretsmanager:ap-southeast-1:629687551655:secret:yehubv1-prod-app-sm-y8jsgI:S3_REGION
    S3_BUCKET:     arn:aws:secretsmanager:ap-southeast-1:629687551655:secret:yehubv1-prod-app-sm-y8jsgI:S3_BUCKET
    S3_ACCESS_KEY: arn:aws:secretsmanager:ap-southeast-1:629687551655:secret:yehubv1-prod-app-sm-y8jsgI:S3_ACCESS_KEY
    S3_SECRET_KEY: arn:aws:secretsmanager:ap-southeast-1:629687551655:secret:yehubv1-prod-app-sm-y8jsgI:S3_SECRET_KEY
    APIFY_TOKEN:   arn:aws:secretsmanager:ap-southeast-1:629687551655:secret:yehubv1-prod-app-sm-y8jsgI:APIFY_TOKEN
